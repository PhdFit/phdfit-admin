# Supabase (required for real data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PhdFit FastAPI service (for resume parsing, matching, embeddings)
PHDFIT_API_URL=http://localhost:8000
PHDFIT_API_KEY=your-shared-api-key

# External APIs (optional, for system health checks and data verification)
OPENALEX_EMAIL=your-email@example.com
ZHIPU_API_KEY=your-zhipu-api-key
